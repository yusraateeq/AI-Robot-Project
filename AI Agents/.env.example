# ── Core ──────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=3002
SOCKET_PORT=3001

# ── Database ──────────────────────────────────────────────────────
# SQLite (default — zero config)
# DATABASE_URL=sqlite+aiosqlite:///redstone_crm.db
# PostgreSQL (requires: pip install asyncpg greenlet):
# DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/redstone_crm

# ── OpenAI ────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4o
OPENAI_VOICE=alloy

# ── ElevenLabs ────────────────────────────────────────────────────
ELEVENLABS_API_KEY=your-elevenlabs-api-key
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# ── VICIdial ──────────────────────────────────────────────────────
# VICIDIAL_URL=http://your-vicidial-server:80
# VICIDIAL_USER=admin
# VICIDIAL_PASS=password

# ── SIP Registration ──────────────────────────────────────────────
# SIP_SERVER_IP=
# SIP_EXTENSION=
# SIP_REGISTRATION_PASSWORD=

# ── Firebase Admin (for token verification) ───────────────────────
# Get these from Firebase Console -> Project Settings -> Service Accounts
# FIREBASE_PROJECT_ID=your-project-id
# FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# ── Smart Call Handling ───────────────────────────────────────────
# GREETING_RECORDING=Recording11
# TRANSFER_NUMBER=
# SILENCE_TIMEOUT=3.0
# NO_RESPONSE_ACTION=hangup
